# ARGOS shared environment — copy next to the role you run:
#   cp shared/.env.example pi/vio/.env
#   cp shared/.env.example pi/lidar/.env
#   cp shared/.env.example laptop/.env
# Keep the SAME ROS_DOMAIN_ID and peer IPs on every host.

# --- Images (laptop / optional VIO container) ---
IMAGE_REGISTRY=argos
IMAGE_TAG=latest

# --- ROS / DDS (must match on all hosts) ---
ROS_DOMAIN_ID=42
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# Multi-host CycloneDDS peers (LAN IPs — not 127.0.0.1).
# Roles: Pi A = lidar, Pi B = VIO (Blackfly+IMU+2×Vivotek), laptop = showcase/COLMAP.
# Laptop SUBSCRIBES on the domain — no Pi "forward" hop. Bandwidth is the limit.
PI_LIDAR_IP=192.168.1.51
PI_VIO_IP=192.168.1.52
LAPTOP_IP=192.168.1.60

# Optional legacy alias (unused by current templates; prefer PI_VIO_IP).
# PI_IP=

# --- Time sync (host OS, not Docker) ---
# See shared/docs/time_sync.md and shared/scripts/setup_chrony.sh
CHRONY_NTP_SERVER=192.168.1.60

# --- Foxglove ---
FOXGLOVE_PORT=8765
# Live showcase: whitelist odom / map / scan|cloud (compressed) — NOT raw 3-cam streams.
# FOXGLOVE_TOPIC_WHITELIST=/ov_msckf/odomimu|/tf|/tf_static|/scan|/rtabmap/.*

# --- Cameras on Pi B ---
# Blackfly = live VIO front-end only (OpenVINS). Prefer these names; CAMERA_* aliases
# are kept for OpenVINS/RTABMAP scripts that already read CAMERA_IMAGE_TOPIC.
BLACKFLY_IMAGE_TOPIC=/blackfly/image_raw
BLACKFLY_INFO_TOPIC=/blackfly/camera_info
CAMERA_IMAGE_TOPIC=/blackfly/image_raw
CAMERA_INFO_TOPIC=/blackfly/camera_info
CAMERA_FRAME_ID=blackfly_link

# 2× Vivotek = photogrammetry / COLMAP only — do NOT feed into OpenVINS.
VIVOTEK_LEFT_TOPIC=/vivotek/left/image_raw
VIVOTEK_LEFT_INFO_TOPIC=/vivotek/left/camera_info
VIVOTEK_RIGHT_TOPIC=/vivotek/right/image_raw
VIVOTEK_RIGHT_INFO_TOPIC=/vivotek/right/camera_info
VIVOTEK_LEFT_FRAME_ID=vivotek_left_link
VIVOTEK_RIGHT_FRAME_ID=vivotek_right_link

# --- IMU (Pi B; raw only — no Madgwick into OpenVINS) ---
# CONFIRMED: on this driver /imu/data IS the raw IMU topic (despite the usual ROS
# convention where /imu/data is the fused/Madgwick output). This is the SAME topic
# the Allan-variance bag imu_allan_20260717_1411 used and what OpenVINS must consume.
# Do NOT point this at any Madgwick-filtered topic.
IMU_TOPIC=/imu/data
IMU_FRAME_ID=imu_link

# OpenVINS default odom (nav_msgs/Odometry). Remap RTABMAP `odom` → this.
OV_ODOM_TOPIC=/ov_msckf/odomimu
# OpenVINS odometry header.frame_id (default in ov_msckf is often "global").
OV_ODOM_FRAME_ID=global

# --- LiDAR topics (Pi A publishes; mapper prefers local consume on Pi A) ---
LIDAR_SCAN_TOPIC=/scan
LIDAR_CLOUD_TOPIC=/points
LIDAR_FRAME_ID=laser_link

# --- RTABMAP ---
# Preferred mapper: native on Pi A (lidar) — see pi/lidar/scripts/run_rtabmap_host.sh
# Alternative: Pi B (pi/vio/scripts/run_rtabmap_host.sh) or laptop live / offline bags.
RTABMAP_DATABASE_PATH=/data/rtabmap.db
# Fresh map each live run on a Pi; prefer false for laptop reprocess.
RTABMAP_DELETE_DB_ON_START=true
# On Pi A preferred path set true once chrony + extrinsics are trusted.
RTABMAP_USE_LIDAR=false

# --- OpenVINS config paths ---
# Templates live under shared/config/openvins/; rendered under /tmp or a local run dir.
OV_CONFIG_DIR=/workspace/config/openvins
OV_ESTIMATOR_CONFIG=/tmp/openvins/estimator_config.yaml
OV_CAM_CONFIG_TEMPLATE=/workspace/config/openvins/kalibr_imucam_chain.yaml.template
OV_IMU_CONFIG_TEMPLATE=/workspace/config/openvins/kalibr_imu_chain.yaml.template
OV_ESTIMATOR_TEMPLATE=/workspace/config/openvins/estimator_config.yaml
# Real Blackfly (roam_cam0_filtered Kalibr) resolution — keep in sync with
# shared/config/openvins/kalibr_imucam_chain.yaml.template.
IMAGE_WIDTH=1288
IMAGE_HEIGHT=728
# Measured IMU output rate ~199.6 Hz (imu_allan_20260717_1411 bag).
IMU_RATE_HZ=200

# --- Recording (general + COLMAP profile) ---
BAG_OUTPUT_DIR=/data/bags
BAG_STORAGE_ID=mcap
BAG_NAME=
# COLMAP: target image rate for Vivotek bags (Hz). Script throttles when possible.
COLMAP_IMAGE_RATE_HZ=2
# Include Blackfly in COLMAP bag (optional; usually leave false — VIO cam is separate).
COLMAP_INCLUDE_BLACKFLY=false

# --- Laptop / GUI ---
DISPLAY=:0
USE_SIM_TIME=false
# Playback only: set USE_SIM_TIME=true and play bags with --clock.
PLAYBACK_RUN_OPENVINS=false
